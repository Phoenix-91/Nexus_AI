# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
.env
.env.local
.env.production

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# MyPy
.mypy_cache/
.dmypy.json

# Uploads / temp files
uploads/
tmp/
temp/
*.webm
*.mp3
*.wav
*.mp4

# Jupyter
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Model cache (Hugging Face, etc.) — only ignore top-level cache, not app/models package
.cache/
.cache/models/
# Explicitly allow the app/models Python package
!app/models/
